{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "启动 Tauri 开发模式",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/dev.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "启动前端开发服务器",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/web.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "构建 Windows 发布版",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/build.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "检查开发环境",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/check.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    }
  ]
}
