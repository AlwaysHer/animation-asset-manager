{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "category": "DeveloperTool",
    "shortDescription": "Animation Asset Manager",
    "longDescription": "Cross-platform animation asset manager with frame-by-frame preview, annotation, and DCC integration"
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "dialog": {
      "open": true,
      "save": true
    },
    "fs": {
      "scope": ["$APPDATA/**", "$HOME/**", "$DESKTOP/**"]
    }
  },
  "productName": "Animation Asset Manager",
  "version": "0.1.0",
  "identifier": "com.aam.app",
  "app": {
    "security": {
      "csp": null,
      "capabilities": ["default"]
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Animation Asset Manager",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700
      }
    ]
  }
}
